<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- TITULO -->
        <TextView
            android:id="@+id/lblTitulo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#16213E"
            android:gravity="center"
            android:padding="20dp"
            android:text="💧 HydroBovi"
            android:textColor="#00B4D8"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- ESTADO CONEXION -->
        <TextView
            android:id="@+id/lblConexion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:padding="8dp"
            android:text="❌ Desconectado"
            android:textColor="#E63946"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- ESTADO TANQUE -->
        <TextView
            android:id="@+id/lblEstado"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#0F3460"
            android:gravity="center"
            android:padding="30dp"
            android:text="Estado: --"
            android:textColor="#FFFFFF"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- FLOTADORES -->
        <TextView
            android:id="@+id/lblBajo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#16213E"
            android:gravity="center"
            android:padding="20dp"
            android:text="Flotador Bajo: --"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/lblAlto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="#16213E"
            android:gravity="center"
            android:padding="20dp"
            android:text="Flotador Alto: --"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- CAUDAL -->
        <TextView
            android:id="@+id/lblCaudal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#0F3460"
            android:gravity="center"
            android:padding="25dp"
            android:text="💧 Caudal: -- L/m"
            android:textColor="#00B4D8"
            android:textSize="24sp"
            android:textStyle="bold" />

        <!-- VALVULA -->
        <TextView
            android:id="@+id/lblValvula"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="#16213E"
            android:gravity="center"
            android:padding="20dp"
            android:text="🔧 Válvula: --"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnConectar"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:backgroundTint="#00B4D8"
                android:text="🔵 Conectar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnDesconectar"
                android:layout_width="0dp"
                android:layout_height="60dp"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:backgroundTint="#E63946"
                android:text="❌ Desconectar"
                android:textColor="#FFFFFF"
                android:textSize="16sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
